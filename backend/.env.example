# Cloudinary — product images (optional; see config/cloudinary.js)
# CLOUDINARY_FOLDER=ecommerce/products
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

PORT=8000
NODE_ENV=production
MONGODB_URL=
JWT_SECRET=
CLIENT_URL=http://localhost:5173

# ==============================================================================
# SECURITY CONFIGURATION (IMPORTANT)
# ==============================================================================

# Admin users are now managed in the database, not .env
# Use POST /api/auth/admin-login with email/password stored in AdminUser model
# The first admin should be created via a setup script or database directly

FIREBASE_PROJECT_ID=your-firebase-project-id

# Password reset emails — Gmail requires an App Password (NOT your normal Gmail password):
# 1) Google Account → Security → turn on 2-Step Verification
# 2) App passwords → create one for "Mail"
# 3) Paste the 16-character password below (remove spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=abcd efgh ijkl mnop
EMAIL_FROM=you@gmail.com
RESET_EMAIL_SUBJECT=Password reset

# Optional: Set to true for SMTP debugging in terminal
# SMTP_DEBUG=true

